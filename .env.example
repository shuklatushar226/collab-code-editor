# Application
NODE_ENV=development
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=collab_editor
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_POOL_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=86400

# JWT Authentication
JWT_SECRET=your-very-long-random-secret-key-here-at-least-64-chars
JWT_EXPIRES_IN=7d

# Code Executor Service
EXECUTOR_URL=http://localhost:3003
EXECUTOR_TIMEOUT_MS=30000

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Version History
MAX_VERSIONS_PER_FILE=50
AUTO_SAVE_INTERVAL_MS=30000

# Optional: AI suggestions
OPENAI_API_KEY=
